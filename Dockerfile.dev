# syntax=docker/dockerfile:1.7

FROM golang:1.25-bookworm AS app-dev

WORKDIR /app
ARG NSJAIL_VERSION=3.6

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
       autoconf \
       bison \
       ca-certificates \
       flex \
       gcc \
       g++ \
       git \
       libnl-route-3-dev \
       libprotobuf-dev \
       libtool \
       make \
       nodejs \
       npm \
       pkg-config \
       protobuf-compiler \
       python3 \
       python3-pip \
       python3-venv \
       sqlite3 \
    && git clone --branch "${NSJAIL_VERSION}" --depth 1 https://github.com/google/nsjail.git /tmp/nsjail-src \
    && cd /tmp/nsjail-src \
    && make \
    && install -m 0755 /tmp/nsjail-src/nsjail /usr/local/bin/nsjail \
    && cd /app \
    && rm -rf /tmp/nsjail-src \
    && npm install -g pnpm@10 \
    && rm -rf /var/lib/apt/lists/*

CMD ["bash"]
